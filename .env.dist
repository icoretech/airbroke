# Sample .env.dist file for Airbroke
# Please rename this file to .env and fill in the appropriate values.

# no need to set these if using docker-compose, unless you want to go pgbouncer
# DATABASE_URL="postgresql://airbroke:airbroke@localhost:6432/airbroke-development?schema=public&pgbouncer=true"
# DIRECT_URL="postgresql://airbroke:airbroke@localhost:5432/airbroke-development?schema=public"

# When self-hosting your Next.js application across multiple servers,
# each server instance may end up with a different encryption key, leading to potential inconsistencies.
# Next.js applications deployed to Vercel automatically handle this.
# This variable **must** be AES-GCM encrypted.
# Generate one with `openssl rand -base64 32`
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=replaceme

# Endpoint protection (CORS for /api/v3/notices and /api/sentry/*/envelope)
AIRBROKE_CORS_ORIGINS="http://localhost:3000,https://my.browserapp.tld"

# AI toolbox
AIRBROKE_OPENAI_API_KEY="sk-xxx"
AIRBROKE_OPENAI_ORGANIZATION=""
AIRBROKE_OPENAI_ENGINE="gpt-4o"

# MCP API (for LLM/agent integrations)
# Set this to enable /api/mcp.
AIRBROKE_MCP_API_KEY=""
# Optional: comma-separated list of allowed browser Origin values for MCP requests.
# If unset, same-origin browser requests are allowed by default.
AIRBROKE_MCP_ALLOWED_ORIGINS=""

# Authentication
AUTH_SECRET="replaceme"          # A random string used to hash tokens, sign cookies and generate cryptographic keys.
AUTH_URL="http://localhost:3000" # The URL of your application, used for signing cookies and OAuth secrets, defaults to http://localhost:3000
AUTH_DEBUG="false"
AUTH_TRUST_HOST="true"          # Keep true behind a trusted proxy; set false to avoid trusting forwarded host headers and rely on AUTH_URL.

AIRBROKE_GITHUB_ID=""
AIRBROKE_GITHUB_SECRET=""
AIRBROKE_GITHUB_ORGS="" # optional, if you want to restrict access to specific organization(s), comma separated

AIRBROKE_ATLASSIAN_ID=""
AIRBROKE_ATLASSIAN_SECRET=""
AIRBROKE_ATLASSIAN_SITES="" # optional, restrict to Atlassian site name(s), comma separated

AIRBROKE_GOOGLE_ID=""
AIRBROKE_GOOGLE_SECRET=""
AIRBROKE_GOOGLE_DOMAINS="" # optional, if you want to restrict access to specific domain(s), comma separated

AIRBROKE_COGNITO_ID=""
AIRBROKE_COGNITO_SECRET=""
AIRBROKE_COGNITO_ISSUER="" # a URL, that looks like this: https://cognito-idp.{region}.amazonaws.com/{PoolId}

AIRBROKE_GITLAB_ID=""
AIRBROKE_GITLAB_SECRET=""
AIRBROKE_GITLAB_URL="" # optional, self-hosted GitLab URL, defaults to https://gitlab.com
AIRBROKE_GITLAB_GROUPS="" # optional, restrict to GitLab group full_path(s), comma separated

AIRBROKE_APPLE_ID=""
AIRBROKE_APPLE_SECRET=""

AIRBROKE_SLACK_ID=""
AIRBROKE_SLACK_SECRET=""
AIRBROKE_SLACK_WORKSPACES="" # optional, restrict to Slack workspace/team ID(s), comma separated

AIRBROKE_KEYCLOAK_ID=""
AIRBROKE_KEYCLOAK_SECRET=""
AIRBROKE_KEYCLOAK_ISSUER="" # issuer should include the realm e.g. https://my-keycloak-domain.com/realms/My_Realm

AIRBROKE_OKTA_ID=""
AIRBROKE_OKTA_SECRET=""
AIRBROKE_OKTA_ISSUER="" # https://{yourOktaDomain}/oauth2/default

AIRBROKE_AUTHENTIK_ID=""
AIRBROKE_AUTHENTIK_SECRET=""
AIRBROKE_AUTHENTIK_ISSUER="" # issuer should include the slug without a trailing slash e.g., https://my-authentik-domain.com/application/o/My_Slug

AIRBROKE_MICROSOFT_ENTRA_ID_CLIENT_ID=""
AIRBROKE_MICROSOFT_ENTRA_ID_CLIENT_SECRET=""
AIRBROKE_MICROSOFT_ENTRA_ID_ISSUER=""
AIRBROKE_MICROSOFT_ENTRA_ID_TENANTS="" # optional, restrict to Azure AD tenant ID(s), comma separated

AIRBROKE_AUTH0_ID=""
AIRBROKE_AUTH0_SECRET=""
AIRBROKE_AUTH0_ISSUER="" # Your Auth0 tenant URL, e.g. https://your-tenant.us.auth0.com
AIRBROKE_AUTH0_DOMAINS="" # optional, restrict to email domain(s), comma separated

AIRBROKE_BOXYHQ_SAML_ID="" # use "dummy" if Jackson manages tenant routing
AIRBROKE_BOXYHQ_SAML_SECRET=""
AIRBROKE_BOXYHQ_SAML_ISSUER="" # Base URL of your BoxyHQ Jackson instance, e.g. http://localhost:5225
AIRBROKE_BOXYHQ_SAML_TENANT="" # optional, Jackson tenant for SAML routing
AIRBROKE_BOXYHQ_SAML_PRODUCT="" # optional, Jackson product for SAML routing
AIRBROKE_BOXYHQ_SAML_DOMAINS="" # optional, restrict to email domain(s), comma separated

AIRBROKE_BITBUCKET_ID=""
AIRBROKE_BITBUCKET_SECRET=""
AIRBROKE_BITBUCKET_WORKSPACES="" # optional, restrict to workspace slug(s), comma separated

AIRBROKE_SALESFORCE_ID=""
AIRBROKE_SALESFORCE_SECRET=""
AIRBROKE_SALESFORCE_ORGS="" # optional, restrict to Salesforce organization ID(s), comma separated

AIRBROKE_FUSIONAUTH_ID=""
AIRBROKE_FUSIONAUTH_SECRET=""
AIRBROKE_FUSIONAUTH_ISSUER="" # Your FusionAuth instance URL, e.g. https://auth.example.com
AIRBROKE_FUSIONAUTH_TENANT_ID="" # optional, FusionAuth tenant ID for multi-tenant setups
AIRBROKE_FUSIONAUTH_DOMAINS="" # optional, restrict to email domain(s), comma separated
